# MongoDB Configuration
# Replace with your MongoDB connection details

# Option 1: Local MongoDB (Development)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=firco_local

# Option 2: MongoDB Atlas (Production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
# MONGODB_DATABASE=firco_production

# AWS S3 Configuration (Optional - for model storage and backups)
# Uncomment and configure if you want to use S3 for model persistence

# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_S3_BUCKET_NAME=your_bucket_name
# AWS_S3_REGION=us-east-1

# API Configuration (Optional)
# API_HOST=0.0.0.0
# API_PORT=3004

# Model Configuration (Optional)
# MODEL_VERSION_PREFIX=v
# AUTO_ARCHIVE_MODELS=true
# MAX_MODEL_VERSIONS=10

# Logging Configuration (Optional)
# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

